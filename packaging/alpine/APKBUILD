# Contributor: coredoc contributors <noreply@users.noreply.github.com>
# Maintainer: coredoc contributors <noreply@users.noreply.github.com>
pkgname=coredoc
pkgver=0.2.0
pkgrel=0
pkgdesc="Modular TUI-based Linux diagnostics and first-aid tool"
url="https://github.com/CoreOG-fr/coredoc"
arch="noarch"
license="MIT"
depends="python3 py3-textual"
makedepends="py3-setuptools py3-wheel py3-build py3-installer"
source="$pkgname-$pkgver.tar.gz"
builddir="$srcdir/$pkgname-$pkgver"
options="!check"

build() {
	python3 -m build --wheel --no-isolation
}

check() {
	python3 -m pytest
}

package() {
	python3 -m installer --destdir="$pkgdir" dist/*.whl
	install -Dm644 man/coredoc.1 "$pkgdir/usr/share/man/man1/coredoc.1"
}

sha512sums="SKIP"
